---
import type { Translations } from '../i18n/index';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="about" class="relative py-28 overflow-hidden" style="background:#0d1f38;">

  <!-- Diagonal top -->
  <div class="absolute top-0 left-0 right-0 h-20 overflow-hidden pointer-events-none">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <polygon points="0,0 1440,80 1440,0" fill="#0a1628"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Left: Metric column visual -->
      <div class="reveal-left order-2 lg:order-1">
        <div class="relative">
          <!-- Accent line -->
          <div class="absolute left-0 top-0 bottom-0 w-px" style="background:linear-gradient(180deg, transparent, #00b4d8, transparent);"></div>

          <!-- Metric blocks -->
          <div class="pl-8 space-y-6">
            {[
              { num: '+500', label: 'Unidades en operación activa', icon: 'local_shipping' },
              { num: '15+',  label: 'Años como concesionario oficial', icon: 'workspace_premium' },
              { num: '100%', label: 'Satisfacción en postventa certificada', icon: 'verified' },
              { num: '24/7', label: 'Línea de emergencia técnica', icon: 'support_agent' },
            ].map((m, i) => (
              <div class={`flex items-center gap-6 p-5 glass-card group hover:border-cyan/40 transition-all duration-300 reveal stagger-${i+1}`}>
                <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center"
                  style="background:rgba(0,180,216,0.08);border:1px solid rgba(0,180,216,0.2);">
                  <span class="material-symbols-outlined" style="color:#00b4d8;font-size:1.25rem;">{m.icon}</span>
                </div>
                <div>
                  <p class="font-heading font-900 text-cyan" style="font-size:2rem;font-weight:900;line-height:1;">{m.num}</p>
                  <p class="text-steel text-sm" style="font-weight:300;font-size:.82rem;">{m.label}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Text content -->
      <div class="order-1 lg:order-2">
        <div class="section-badge mb-6 reveal">
          <span class="material-symbols-outlined" style="font-size:.85rem;">business</span>
          {t.about.badge}
        </div>

        <h2 class="font-heading font-900 text-white mb-8 reveal"
          style="font-size:clamp(1.8rem,4vw,3rem);font-weight:900;letter-spacing:-.02em;line-height:1.05;">
          {t.about.title}
        </h2>

        <div class="space-y-5 reveal">
          <p class="text-ash leading-relaxed" style="font-weight:300;">{t.about.text1}</p>
          <p class="text-ash leading-relaxed" style="font-weight:300;">{t.about.text2}</p>
        </div>

        <!-- Certs -->
        <div class="mt-10 reveal">
          <p class="font-heading font-700 text-cyan text-xs tracking-widest uppercase mb-5" style="letter-spacing:.2em;font-size:.65rem;">{t.about.certTitle}</p>
          <div class="flex flex-wrap gap-3">
            {t.about.certs.map(cert => (
              <span class="glass-card px-4 py-2 text-ash text-xs font-semibold" style="font-size:.75rem;border-radius:0;">
                {cert}
              </span>
            ))}
          </div>
        </div>

        <!-- Diagonal accent bar -->
        <div class="mt-12 h-1 w-full reveal"
          style="background:linear-gradient(90deg, #00b4d8, #1b4fb3, transparent);clip-path:polygon(0 0,95% 0,100% 100%,0 100%);"></div>
      </div>
    </div>
  </div>

  <!-- Diagonal bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-20 overflow-hidden pointer-events-none">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <polygon points="0,80 1440,0 1440,80" fill="#0a1628"/>
    </svg>
  </div>
</section>
