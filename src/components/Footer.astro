---
import type { Locale, Translations } from '../i18n/index';
import logoImg from '../assets/logo.svg';
import logoMobImg from '../assets/logoMob.svg';

interface Props { lang: Locale; t: Translations; }
const { t } = Astro.props;
---

<footer class="bg-white border-t border-slate-100">
  <div class="flex flex-col md:flex-row justify-between items-center px-5 sm:px-8 md:px-12 lg:px-24 py-8 sm:py-10 w-full max-w-screen-2xl mx-auto gap-8">

    <!-- Brand -->
    <div class="flex flex-col items-center md:items-start">
      <div class="flex items-center justify-center md:justify-start mb-2 w-full md:w-auto">
        <img
          src={logoImg.src}
          alt="Valdivia Automotores"
          width={316}
          height={36}
          class="hidden h-7 w-auto max-w-[min(100%,260px)] sm:block md:h-8"
          loading="lazy"
          decoding="async"
        />
        <img
          src={logoMobImg.src}
          alt="Valdivia Automotores"
          width={306}
          height={153}
          class="block h-12 w-auto max-w-[180px] sm:hidden"
          loading="lazy"
          decoding="async"
        />
      </div>
      <p class="text-xs font-headline uppercase font-bold text-slate-400" style="letter-spacing:.2em;">{t.footer.copy}</p>
    </div>

    <!-- Links -->
    <div class="flex flex-wrap justify-center gap-x-10 gap-y-3">
      {t.footer.links.map(link => (
        <a href="#"
          class="text-xs font-headline font-bold uppercase text-slate-500 hover:text-primary transition-colors"
          style="letter-spacing:.18em;">
          {link}
        </a>
      ))}
    </div>

    <!-- Social icons -->
    <div class="flex gap-4">
      <span class="material-symbols-outlined text-slate-300 cursor-pointer hover:text-primary transition-colors" style="font-size:1.3rem;">public</span>
      <span class="material-symbols-outlined text-slate-300 cursor-pointer hover:text-primary transition-colors" style="font-size:1.3rem;">share</span>
    </div>
  </div>
</footer>
