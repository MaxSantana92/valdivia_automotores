      <path d="M40 70 L75 28 L250 28 L280 70 Z" fill="#dce8f4" stroke="#c8d8ea" stroke-width="1.5"/>
      <path d="M55 68 L82 36 L235 36 L258 68 Z" fill="#1b4fb3" opacity=".1"/>
      <line x1="168" y1="30" x2="168" y2="68" stroke="#c8d8ea" stroke-width="1"/>
      <circle cx="90"  cy="135" r="30" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
      <circle cx="90"  cy="135" r="16" fill="#3a4a5a"/>
      <circle cx="90"  cy="135" r="7"  fill="#1b4fb3" opacity=".7"/>
      <circle cx="230" cy="135" r="30" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
      <circle cx="230" cy="135" r="16" fill="#3a4a5a"/>
      <circle cx="230" cy="135" r="7"  fill="#1b4fb3" opacity=".7"/>
      <rect x="270" y="80" width="14" height="18" rx="3" fill="#fff8e0" stroke="#e0d090" stroke-width="1"/>
      <rect x="30" y="92" width="18" height="30" rx="4" fill="#b0c0d0"/>
      <!-- Roll bar -->
      <rect x="88"  y="27" width="6" height="42" rx="2" fill="#1b4fb3" opacity=".5"/>
      <rect x="218" y="27" width="6" height="42" rx="2" fill="#1b4fb3" opacity=".5"/>
      <rect x="88"  y="28" width="136" height="5" rx="2" fill="#1b4fb3" opacity=".4"/>
      <!-- Lights on bar -->
      <rect x="108" y="24" width="14" height="8" rx="2" fill="#00b4d8" opacity=".8"/>
      <rect x="148" y="24" width="14" height="8" rx="2" fill="#00b4d8" opacity=".8"/>
      <rect x="188" y="24" width="14" height="8" rx="2" fill="#00b4d8" opacity=".8"/>
    </svg>`,
  BYD: `
    <svg viewBox="0 0 320 160" fill="none" class="w-full h-52 object-contain">
      <!-- Electric van body -->
      <rect x="30" y="45" width="260" height="90" rx="14" fill="#e8f4fb" stroke="#b8d8f0" stroke-width="1.5"/>
      <rect x="30" y="45" width="260" height="14" rx="14" fill="#0a9cc0"/>
      <!-- Windows -->
      <rect x="50"  y="60" width="70" height="50" rx="6" fill="#00b4d8" opacity=".15"/>
      <rect x="135" y="60" width="70" height="50" rx="6" fill="#00b4d8" opacity=".12"/>
      <rect x="220" y="60" width="55" height="50" rx="6" fill="#00b4d8" opacity=".1"/>
      <line x1="130" y1="58" x2="130" y2="112" stroke="#b8d8f0" stroke-width="1.5"/>
      <line x1="215" y1="58" x2="215" y2="112" stroke="#b8d8f0" stroke-width="1.5"/>
