      <!-- Wheels -->
      <circle cx="85"  cy="138" r="24" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
      <circle cx="85"  cy="138" r="13" fill="#00b4d8" opacity=".3"/>
      <circle cx="235" cy="138" r="24" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
