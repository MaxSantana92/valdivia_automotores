      <!-- Headlights -->
      <rect x="22" y="56" width="12" height="18" rx="2" fill="#fff8e0" stroke="#e0d090"/>
      <!-- Cargo bed -->
      <rect x="120" y="60" width="185" height="70" rx="4" fill="#c8d8e8" stroke="#b0c0d0" stroke-width="1.5"/>
      <!-- Cargo slats -->
      <line x1="155" y1="62" x2="155" y2="128" stroke="#b0c0d0" stroke-width="1"/>
      <line x1="195" y1="62" x2="195" y2="128" stroke="#b0c0d0" stroke-width="1"/>
      <line x1="235" y1="62" x2="235" y2="128" stroke="#b0c0d0" stroke-width="1"/>
      <line x1="275" y1="62" x2="275" y2="128" stroke="#b0c0d0" stroke-width="1"/>
      <!-- Wheels -->
      <circle cx="65"  cy="135" r="26" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
      <circle cx="65"  cy="135" r="14" fill="#3a4a5a"/>
      <circle cx="65"  cy="135" r="6"  fill="#c8d8e8"/>
      <circle cx="220" cy="135" r="26" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
      <circle cx="220" cy="135" r="14" fill="#3a4a5a"/>
      <circle cx="220" cy="135" r="6"  fill="#c8d8e8"/>
      <circle cx="270" cy="135" r="26" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="2"/>
      <circle cx="270" cy="135" r="14" fill="#3a4a5a"/>
      <circle cx="270" cy="135" r="6"  fill="#c8d8e8"/>
    </svg>`,
};
---

<section id="catalog" class="scroll-reveal reveal-left py-24 bg-white text-secondary px-8 md:px-16 lg:px-24">
  <div class="max-w-7xl mx-auto">

    <!-- Header row -->
    <div class="flex flex-col md:flex-row justify-between items-baseline mb-16 gap-6">
      <div>
        <h2 class="text-sm font-headline text-primary uppercase mb-4" style="letter-spacing:.3em;">{t.catalog.badge}</h2>
        <h3 class="font-headline font-black uppercase" style="font-size:clamp(2rem,5vw,3.75rem);">{t.catalog.title}</h3>
      </div>
      <button class="font-headline uppercase font-bold text-primary border-b-2 border-primary pb-1 hover:text-secondary hover:border-secondary transition-colors" style="letter-spacing:.15em;font-size:.875rem;">
        {t.catalog.see_all}
      </button>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 stagger">
      {t.catalog.vehicles.map((v) => (
        <div class="perspective-card group scroll-reveal reveal-up">
          <div class="perspective-card-inner bg-surface rounded-3xl p-8 border border-slate-100 relative overflow-hidden shadow-sm"
            style="height:540px;">

            <!-- Watermark brand -->
            <div class="absolute top-6 right-8 font-headline font-black text-secondary opacity-5"
              style="font-size:3.5rem;">{v.brand}</div>

            <!-- Vehicle SVG illustration -->
            <div class="skeleton-loader rounded-lg overflow-hidden mt-4 group-hover:[&>svg]:scale-110">
              <div class="transition-transform duration-500" set:html={brandSvgs[v.brand] ?? brandSvgs['BAIC']} />
            </div>

            <!-- Info -->
            <div class="mt-6">
              <h4 class="text-2xl font-headline font-bold uppercase tracking-tight text-secondary">{v.model}</h4>
              <p class="text-slate-500 mt-2 text-sm font-medium">{v.desc}</p>

              <!-- Tags -->
              <div class="mt-5 flex flex-wrap gap-3">
                {v.tags.map((tag, ti) => (
                  <span class={`text-xs font-headline uppercase font-bold px-3 py-1 rounded-full ${
                    v.tag_style[ti] === 'primary'
                      ? 'bg-primary/10 text-primary'
                      : 'bg-white border border-slate-200 text-slate-600'
                  }`}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Hover CTA (slides up) -->
            <div class="absolute bottom-8 left-8 right-8 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <button class="diagonal-btn w-full bg-secondary text-white py-4 font-headline font-bold text-sm" style="letter-spacing:.2em;">
                {t.catalog.cta}
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
