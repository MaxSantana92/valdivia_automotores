      <!-- Ground shadow -->
      <ellipse cx="160" cy="160" rx="140" ry="8" fill="#6a7a8a" opacity=".08"/>
    </svg>`,
  FOTON: `
    <svg viewBox="0 0 320 160" fill="none" class="w-full h-52 object-contain">
      <!-- Heavy truck cab -->
      <rect x="20" y="40" width="100" height="90" rx="8" fill="#dce8f4" stroke="#c0d0e0" stroke-width="1.5"/>
      <!-- Windshield -->
