---
import type { Translations } from '../i18n/index';
interface Props { t: Translations; }
const { t } = Astro.props;
const MSG_MAX = 500;
---

<section id="contact" class="scroll-reveal reveal-left py-16 sm:py-20 md:py-24 bg-surface px-5 sm:px-8 md:px-16 lg:px-24 border-t border-slate-100">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 lg:gap-24 items-start max-w-7xl mx-auto">

    <!-- Left: Info -->
    <div>
      <h3 class="text-sm font-headline text-primary uppercase mb-4" style="letter-spacing:.3em;">{t.contact.badge}</h3>
      <h4 class="font-headline font-black uppercase text-secondary leading-tight"
        style="font-size:clamp(2rem,5vw,3.5rem);">
        {t.contact.title1}<br/>
        {t.contact.title2}
        <span class="text-primary"> {t.contact.title3}</span>
      </h4>
      <p class="mt-8 text-slate-600 font-medium leading-relaxed">{t.contact.body}</p>

      <div class="mt-12 space-y-6">
        {[
          { icon: 'call',        text: t.contact.phone   },
          { icon: 'mail',        text: t.contact.email   },
          { icon: 'location_on', text: t.contact.address },
        ].map(c => (
          <div class="flex items-center gap-6 group">
            <div class="w-12 h-12 bg-white rounded-xl shadow-sm border border-slate-100 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all duration-200 flex-shrink-0 group-hover:scale-105">
              <span class="material-symbols-outlined" style="font-size:1.25rem;">{c.icon}</span>
            </div>
            <span class="font-bold text-secondary text-base sm:text-lg break-words min-w-0">{c.text}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Form -->
    <div id="contact-form-card" class="bg-white p-6 sm:p-10 md:p-12 shadow-2xl rounded-2xl sm:rounded-3xl border border-slate-50 transition-all duration-500">
      <form id="contact-form" novalidate class="space-y-8">
        <input type="text" name="_honey" style="display:none;" tabindex="-1" autocomplete="off" />

        <div class="form-group">
          <label class="form-lbl" for="cf-name">{t.contact.fields.name}</label>
          <input id="cf-name" type="text" name="name" required
            placeholder={t.contact.placeholders.name}
            class="input-underline" autocomplete="name" />
          <span class="form-err hidden text-red-500 text-xs mt-1 font-medium"></span>
        </div>

        <div class="form-group">
          <label class="form-lbl" for="cf-email">{t.contact.fields.email}</label>
          <input id="cf-email" type="email" name="email" required
            placeholder={t.contact.placeholders.email}
            class="input-underline" autocomplete="email" />
          <span class="form-err hidden text-red-500 text-xs mt-1 font-medium"></span>
        </div>

        <div class="form-group">
          <label class="form-lbl" for="cf-company">{t.contact.fields.company}</label>
          <input id="cf-company" type="text" name="company" required
            placeholder={t.contact.placeholders.company}
            class="input-underline" autocomplete="organization" />
          <span class="form-err hidden text-red-500 text-xs mt-1 font-medium"></span>
        </div>

        <div class="form-group">
          <label class="form-lbl" for="cf-message">{t.contact.fields.message}</label>
          <textarea id="cf-message" name="message" rows="4" maxlength={MSG_MAX}
            placeholder={t.contact.placeholders.message}
            class="input-underline resize-none"></textarea>
          <div class="flex justify-end mt-1">
            <span id="cf-msg-count" class="text-[10px] font-headline uppercase tracking-wider text-slate-400">0 / {MSG_MAX}</span>
          </div>
        </div>

        <div class="pt-2">
          <button type="submit" id="form-submit"
            class="diagonal-btn w-full bg-primary-gradient text-white px-8 sm:px-10 py-2.5 sm:py-3 text-sm font-headline font-bold disabled:opacity-50 disabled:cursor-not-allowed">
            {t.contact.submit}
          </button>
        </div>
      </form>

      <div id="form-success" class="hidden text-center py-8 opacity-0 scale-95 transition-all duration-500 ease-out">
        <span class="material-symbols-outlined text-primary block mb-3" style="font-size:3rem;font-variation-settings:'FILL' 1,'wght' 400;">check_circle</span>
        <p class="font-headline font-bold text-secondary text-2xl uppercase mb-2" style="letter-spacing:.08em;">{t.contact.success_title}</p>
        <p class="text-slate-500 font-medium">{t.contact.success_body}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .form-lbl {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: .25rem;
    transition: color .2s;
  }
  .form-group:focus-within .form-lbl { color: #1b4fb3; }
  .form-group.is-invalid .form-lbl { color: #ef4444; }
</style>

<script define:vars={{ errRequired: t.contact.err_required, errEmail: t.contact.err_email }}>
  const form = document.getElementById('contact-form');
  const success = document.getElementById('form-success');
  const card = document.getElementById('contact-form-card');
  const msg = document.getElementById('cf-message');
  const msgCount = document.getElementById('cf-msg-count');

  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function setErr(group, message) {
    const err = group?.querySelector('.form-err');
    const inp = group?.querySelector('input, textarea');
    if (!err || !inp) return;
    if (message) {
      err.textContent = message;
      err.classList.remove('hidden');
      group?.classList.add('is-invalid');
      inp.style.borderBottomColor = '#f87171';
    } else {
      err.textContent = '';
      err.classList.add('hidden');
      group?.classList.remove('is-invalid');
      inp.style.borderBottomColor = '';
    }
  }

  msg?.addEventListener('input', () => {
    if (msgCount) msgCount.textContent = `${msg.value.length} / ${msg.maxLength}`;
  });

  form?.querySelectorAll('input[required], textarea').forEach((el) => {
    el.addEventListener('blur', () => {
      const g = el.closest('.form-group');
      const inp = el;
      if (inp.name === 'email' && inp.value.trim()) {
        setErr(g, emailRe.test(inp.value.trim()) ? null : errEmail);
      } else if (inp.required && !inp.value.trim()) {
        setErr(g, errRequired);
      } else {
        setErr(g, null);
      }
    });
    el.addEventListener('input', () => {
      const g = el.closest('.form-group');
      if (g?.classList.contains('is-invalid')) setErr(g, null);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (form.querySelector('[name="_honey"]')?.value) return;

    let valid = true;
    form.querySelectorAll('input[required]').forEach((el) => {
      const inp = el;
      const g = inp.closest('.form-group');
      if (!inp.value.trim()) {
        valid = false;
        setErr(g, errRequired);
      } else if (inp.type === 'email' && !emailRe.test(inp.value.trim())) {
        valid = false;
        setErr(g, errEmail);
      } else {
        setErr(g, null);
      }
    });

    const company = form.querySelector('[name="company"]');
    const gCo = company?.closest('.form-group');
    if (company && !company.value.trim()) {
      valid = false;
      setErr(gCo, errRequired);
    } else if (gCo) setErr(gCo, null);

    if (!valid) return;

    document.getElementById('form-submit')?.setAttribute('disabled', 'true');
    await new Promise((r) => setTimeout(r, 900));
    form.classList.add('hidden');
    success?.classList.remove('hidden');
    requestAnimationFrame(() => {
      success?.classList.remove('opacity-0', 'scale-95');
      success?.classList.add('opacity-100', 'scale-100');
    });
    card?.classList.add('ring-2', 'ring-primary/20');
  });
</script>
