---
import type { Locale, Translations } from '../i18n/index';
import { getLocalePath } from '../i18n/index';
import logoImg from '../assets/logo.svg';
import logoMobImg from '../assets/logoMob.svg';

interface Props { lang: Locale; t: Translations; }
const { lang, t } = Astro.props;
const otherLang: Locale = lang === 'es' ? 'en' : 'es';
---

<nav id="site-nav" class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-xl border-b border-slate-100 transition-shadow duration-300">
  <div class="flex justify-between items-center w-full px-5 sm:px-6 lg:px-8 py-3.5 sm:py-4 max-w-screen-2xl mx-auto">

    <!-- Logo: wordmark escritorio / marca compacta móvil -->
    <a href={getLocalePath(lang)} class="flex items-center shrink-0 min-w-0 group" aria-label="Valdivia Automotores — Inicio">
      <img
        src={logoImg.src}
        alt=""
        width={316}
        height={36}
        class="hidden h-8 w-auto max-h-9 sm:block md:h-9 transition-transform duration-300 group-hover:scale-[1.02]"
        loading="eager"
        decoding="async"
      />
      <img
        src={logoMobImg.src}
        alt=""
        width={306}
        height={153}
        class="block h-10 w-auto max-h-11 sm:hidden transition-transform duration-300 group-hover:scale-[1.02]"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-8">

      <!-- Vehículos dropdown -->
      <div class="nav-dropdown relative group cursor-pointer py-2">
        <div class="nav-link-desk flex items-center gap-1 text-secondary font-headline uppercase tracking-wider text-sm font-bold group-hover:text-primary transition-colors">
          {t.nav.vehicles}
          <span class="material-symbols-outlined" style="font-size:.9rem;">expand_more</span>
        </div>
        <div class="dropdown-menu absolute top-full left-0 w-44 bg-white shadow-2xl rounded-lg p-3 border border-slate-50 mt-1">
          <a href="#catalog" class="block py-2.5 px-3 text-sm font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors">{t.nav.vehicles_0km}</a>
          <a href="#catalog" class="block py-2.5 px-3 text-sm font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors">{t.nav.vehicles_used}</a>
        </div>
      </div>

      <!-- Postventa dropdown -->
      <div class="nav-dropdown relative group cursor-pointer py-2">
        <div class="nav-link-desk flex items-center gap-1 text-secondary font-headline uppercase tracking-wider text-sm font-bold group-hover:text-primary transition-colors">
          {t.nav.aftersales}
          <span class="material-symbols-outlined" style="font-size:.9rem;">expand_more</span>
        </div>
        <div class="dropdown-menu absolute top-full left-0 w-72 bg-white shadow-2xl rounded-lg p-3 border border-slate-50 mt-1">
          {t.nav.aftersales_items.map((item, i) => (
            <a href="#" class={`block py-2.5 px-3 text-xs font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors ${i < t.nav.aftersales_items.length - 1 ? 'border-b border-slate-50' : ''}`}>
              {item}
            </a>
          ))}
        </div>
      </div>

      <!-- Servicios dropdown -->
      <div class="nav-dropdown relative group cursor-pointer py-2">
        <div class="nav-link-desk flex items-center gap-1 text-secondary font-headline uppercase tracking-wider text-sm font-bold group-hover:text-primary transition-colors">
          {t.nav.services}
          <span class="material-symbols-outlined" style="font-size:.9rem;">expand_more</span>
        </div>
        <div class="dropdown-menu absolute top-full left-0 w-52 bg-white shadow-2xl rounded-lg p-3 border border-slate-50 mt-1">
          {t.nav.services_items.map(item => (
            <a href="#" class="block py-2.5 px-3 text-sm font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors">
              {item}
            </a>
          ))}
        </div>
      </div>

      <!-- Nosotros -->
      <a href="#" class="nav-link-desk text-secondary font-headline uppercase tracking-wider text-sm font-bold hover:text-primary transition-colors">
        {t.nav.about}
      </a>
    </div>

    <!-- Right: Lang + CTA + Hamburger -->
    <div class="flex items-center gap-4">
      <!-- Lang toggle -->
      <a href={getLocalePath(otherLang)}
        class="flex items-center gap-1.5 text-secondary hover:text-primary transition-all duration-200 hover:scale-105 rounded-md px-1"
        title="Change language">
        <span class="material-symbols-outlined" style="font-size:1.25rem;">language</span>
        <span class="font-headline font-bold text-xs uppercase" style="letter-spacing:.15em;">{otherLang.toUpperCase()}</span>
      </a>

      <!-- CTA button -->
      <a href="#contact"
        class="diagonal-btn bg-primary-gradient text-white px-7 py-2.5 text-sm hidden md:inline-flex">
        {t.nav.cta}
      </a>

      <!-- Hamburger -->
      <button id="hamburger" type="button" class="lg:hidden p-2 -mr-1 text-secondary hover:text-primary transition-colors rounded-md z-[60] relative" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-panel">
        <span class="material-symbols-outlined icon-menu" aria-hidden="true">menu</span>
        <span class="material-symbols-outlined icon-close hidden" aria-hidden="true">close</span>
      </button>
    </div>
  </div>
</nav>

<!-- Drawer móvil: panel lateral + backdrop -->
<div id="mobile-drawer" class="fixed inset-0 z-40 lg:hidden pointer-events-none invisible" aria-hidden="true">
  <div
    id="mobile-backdrop"
    class="absolute inset-x-0 bottom-0 top-16 bg-slate-900/50 opacity-0 transition-opacity duration-300 ease-out"
  ></div>
  <aside
    id="mobile-panel"
    class="absolute right-0 top-16 bottom-0 w-[min(100%,20rem)] max-w-[85vw] bg-white shadow-2xl flex flex-col px-5 sm:px-6 py-6 gap-1 border-l border-slate-100 transform translate-x-full transition-transform duration-300 ease-out overflow-y-auto overscroll-contain"
  >
    <a href="#catalog"  class="mobile-nav-link py-3 font-headline font-bold uppercase text-sm text-secondary border-b border-slate-50 transition-colors hover:text-primary hover:pl-1">{t.nav.vehicles}</a>
    <a href="#"         class="mobile-nav-link py-3 font-headline font-bold uppercase text-sm text-secondary border-b border-slate-50 transition-colors hover:text-primary hover:pl-1">{t.nav.aftersales}</a>
    <a href="#"         class="mobile-nav-link py-3 font-headline font-bold uppercase text-sm text-secondary border-b border-slate-50 transition-colors hover:text-primary hover:pl-1">{t.nav.services}</a>
    <a href="#"         class="mobile-nav-link py-3 font-headline font-bold uppercase text-sm text-secondary border-b border-slate-50 transition-colors hover:text-primary hover:pl-1">{t.nav.about}</a>
    <a href="#contact"  class="mt-4 diagonal-btn bg-primary-gradient text-white px-8 py-3 text-sm self-start">{t.nav.cta}</a>
  </aside>
</div>

<script>
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('shadow-md', window.scrollY > 30);
  }, { passive: true });

  const btn = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('mobile-backdrop');
  const panel = document.getElementById('mobile-panel');
  const iconMenu = btn?.querySelector('.icon-menu');
  const iconClose = btn?.querySelector('.icon-close');

  function setMenuOpen(open) {
    if (!drawer || !backdrop || !panel || !btn) return;
    if (open) {
      drawer.classList.remove('pointer-events-none', 'invisible');
      drawer.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => {
        backdrop.classList.add('opacity-100');
        panel.classList.remove('translate-x-full');
      });
    } else {
      backdrop.classList.remove('opacity-100');
      panel.classList.add('translate-x-full');
      window.setTimeout(() => {
        drawer.classList.add('pointer-events-none', 'invisible');
        drawer.setAttribute('aria-hidden', 'true');
      }, 300);
    }
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    iconMenu?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    document.body.style.overflow = open ? 'hidden' : '';
  }

  btn?.addEventListener('click', () => {
    const isOpen = backdrop?.classList.contains('opacity-100');
    setMenuOpen(!isOpen);
  });

  backdrop?.addEventListener('click', () => setMenuOpen(false));

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenuOpen(false);
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.classList.contains('invisible')) {
      setMenuOpen(false);
    }
  });
</script>
