---
import type { Locale, Translations } from '../i18n/index';
import { getLocalePath } from '../i18n/index';
import logoImg from '../assets/logo.svg';
import logoMobImg from '../assets/logoMob.svg';

interface Props { lang: Locale; t: Translations; }
const { lang, t } = Astro.props;
const otherLang: Locale = lang === 'es' ? 'en' : 'es';
---

<nav id="site-nav" class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-xl border-b border-slate-100 transition-shadow duration-300">
  <div class="flex justify-between items-center w-full px-5 sm:px-6 lg:px-8 py-3.5 sm:py-4 max-w-screen-2xl mx-auto">

    <!-- Logo: wordmark escritorio / marca compacta móvil -->
    <a href={getLocalePath(lang)} class="flex items-center shrink-0 min-w-0 group" aria-label="Valdivia Automotores — Inicio">
      <img
        src={logoImg.src}
        alt=""
        width={316}
        height={36}
        class="hidden h-8 w-auto max-h-9 sm:block md:h-9"
        loading="eager"
        decoding="async"
      />
      <img
        src={logoMobImg.src}
        alt=""
        width={306}
        height={153}
        class="block h-10 w-auto max-h-11 sm:hidden"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-8">

      <!-- Vehículos dropdown -->
      <div class="nav-dropdown relative group cursor-pointer py-2">
        <div class="flex items-center gap-1 text-secondary font-headline uppercase tracking-wider text-sm font-bold group-hover:text-primary transition-colors">
          {t.nav.vehicles}
          <span class="material-symbols-outlined" style="font-size:.9rem;">expand_more</span>
        </div>
        <div class="dropdown-menu absolute top-full left-0 w-44 bg-white shadow-2xl rounded-lg p-3 border border-slate-50 mt-1">
          <a href="#catalog" class="block py-2.5 px-3 text-sm font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors">{t.nav.vehicles_0km}</a>
          <a href="#catalog" class="block py-2.5 px-3 text-sm font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors">{t.nav.vehicles_used}</a>
        </div>
      </div>

      <!-- Postventa dropdown -->
      <div class="nav-dropdown relative group cursor-pointer py-2">
        <div class="flex items-center gap-1 text-secondary font-headline uppercase tracking-wider text-sm font-bold group-hover:text-primary transition-colors">
          {t.nav.aftersales}
          <span class="material-symbols-outlined" style="font-size:.9rem;">expand_more</span>
        </div>
        <div class="dropdown-menu absolute top-full left-0 w-72 bg-white shadow-2xl rounded-lg p-3 border border-slate-50 mt-1">
          {t.nav.aftersales_items.map((item, i) => (
            <a href="#" class={`block py-2.5 px-3 text-xs font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors ${i < t.nav.aftersales_items.length - 1 ? 'border-b border-slate-50' : ''}`}>
              {item}
            </a>
          ))}
        </div>
      </div>

      <!-- Servicios dropdown -->
      <div class="nav-dropdown relative group cursor-pointer py-2">
        <div class="flex items-center gap-1 text-secondary font-headline uppercase tracking-wider text-sm font-bold group-hover:text-primary transition-colors">
          {t.nav.services}
          <span class="material-symbols-outlined" style="font-size:.9rem;">expand_more</span>
        </div>
        <div class="dropdown-menu absolute top-full left-0 w-52 bg-white shadow-2xl rounded-lg p-3 border border-slate-50 mt-1">
          {t.nav.services_items.map(item => (
            <a href="#" class="block py-2.5 px-3 text-sm font-headline uppercase font-bold text-secondary hover:text-primary hover:bg-slate-50 rounded transition-colors">
              {item}
            </a>
          ))}
        </div>
      </div>

      <!-- Nosotros -->
      <a href="#" class="text-secondary font-headline uppercase tracking-wider text-sm font-bold hover:text-primary transition-colors">
        {t.nav.about}
      </a>
    </div>

    <!-- Right: Lang + CTA + Hamburger -->
    <div class="flex items-center gap-4">
      <!-- Lang toggle -->
      <a href={getLocalePath(otherLang)}
        class="flex items-center gap-1.5 text-secondary hover:text-primary transition-colors cursor-pointer"
        title="Change language">
        <span class="material-symbols-outlined" style="font-size:1.25rem;">language</span>
        <span class="font-headline font-bold text-xs uppercase" style="letter-spacing:.15em;">{otherLang.toUpperCase()}</span>
      </a>

      <!-- CTA button -->
      <a href="#contact"
        class="diagonal-btn bg-primary-gradient text-white px-7 py-2.5 text-sm hidden md:inline-flex">
        {t.nav.cta}
      </a>

      <!-- Hamburger -->
      <button id="hamburger" type="button" class="lg:hidden p-2 -mr-1 text-secondary hover:text-primary transition-colors" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
        <span class="material-symbols-outlined icon-menu" aria-hidden="true">menu</span>
        <span class="material-symbols-outlined icon-close hidden" aria-hidden="true">close</span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-slate-100 px-5 sm:px-6 py-5 sm:py-6 flex flex-col gap-1 max-h-[min(70vh,calc(100dvh-5rem))] overflow-y-auto overscroll-contain">
    <a href="#catalog"  class="py-3 font-headline font-bold uppercase text-sm text-secondary hover:text-primary border-b border-slate-50 transition-colors">{t.nav.vehicles}</a>
    <a href="#"         class="py-3 font-headline font-bold uppercase text-sm text-secondary hover:text-primary border-b border-slate-50 transition-colors">{t.nav.aftersales}</a>
    <a href="#"         class="py-3 font-headline font-bold uppercase text-sm text-secondary hover:text-primary border-b border-slate-50 transition-colors">{t.nav.services}</a>
    <a href="#"         class="py-3 font-headline font-bold uppercase text-sm text-secondary hover:text-primary border-b border-slate-50 transition-colors">{t.nav.about}</a>
    <a href="#contact"  class="mt-3 diagonal-btn bg-primary-gradient text-white px-8 py-3 text-sm self-start">{t.nav.cta}</a>
  </div>
</nav>

<script>
  // Shadow on scroll
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('shadow-md', window.scrollY > 30);
  }, { passive: true });

  // Hamburger + menú móvil
  const btn  = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = btn?.querySelector('.icon-menu');
  const iconClose = btn?.querySelector('.icon-close');

  function setMenuOpen(open) {
    if (!menu || !btn) return;
    menu.classList.toggle('hidden', !open);
    menu.classList.toggle('flex', open);
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    iconMenu?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    document.body.style.overflow = open ? 'hidden' : '';
  }

  btn?.addEventListener('click', () => {
    const willOpen = menu?.classList.contains('hidden');
    setMenuOpen(!!willOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenuOpen(false);
  });
</script>
