---
import { Image } from 'astro:assets';
import type { Translations } from '../i18n/index';
import heroBackground from '../assets/vehicles/Toyota-hilux-2026.webp';

interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="hero" class="scroll-reveal reveal-left relative min-h-[100dvh] min-h-screen w-full flex items-center overflow-hidden bg-slate-100 pt-[max(5.25rem,env(safe-area-inset-top,0px))] pb-10 md:pb-12">

  <!-- Foto principal + overlay para legibilidad del copy -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroBackground}
      alt=""
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      class="absolute inset-0 h-full w-full object-cover object-center"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background:linear-gradient(100deg, rgba(255,255,255,.97) 0%, rgba(255,255,255,.88) 38%, rgba(255,255,255,.35) 62%, rgba(255,255,255,.08) 100%);"
      aria-hidden="true"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 px-5 sm:px-8 md:px-16 lg:px-24 w-full max-w-7xl mx-auto">
    <h1 class="font-headline font-black text-secondary leading-none uppercase max-w-3xl tracking-normal"
      style="font-size:clamp(2.5rem, 7vw, 5.5rem);">
      <span class="text-primary block">{t.hero.title2}</span>
      <span class="text-secondary block">{t.hero.title3}</span>
    </h1>

    <p class="mt-6 text-slate-600 max-w-xl font-medium tracking-wide leading-relaxed"
      style="font-size:clamp(.95rem, 1.8vw, 1.15rem);">
      {t.hero.subtitle}
    </p>

    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 w-full sm:w-auto max-w-md sm:max-w-none">
      <a href="#contact"
        class="diagonal-btn bg-primary-gradient text-white px-8 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg text-center justify-center w-full sm:w-auto">
        {t.hero.cta1}
      </a>
      <a href="#catalog"
        class="diagonal-btn border-2 border-secondary text-secondary px-8 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg hover:bg-secondary hover:text-white transition-colors text-center justify-center w-full sm:w-auto">
        {t.hero.cta2}
      </a>
    </div>
  </div>
</section>
