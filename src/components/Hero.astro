---
import type { Translations } from '../i18n/index';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="hero" class="scroll-reveal reveal-left relative min-h-[100dvh] min-h-screen w-full flex items-center overflow-hidden bg-white pt-[max(5.25rem,env(safe-area-inset-top,0px))] pb-10 md:pb-12">

  <!-- Background image placeholder with gradient overlay -->
  <div class="absolute inset-0 z-0">
    <!-- SVG truck illustration as background (full-bleed) -->
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Sky / ground gradient -->
      <defs>
        <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#e8eff8"/>
          <stop offset="100%" stop-color="#c8d8ea"/>
        </linearGradient>
        <linearGradient id="groundGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#8a9aaa"/>
          <stop offset="100%" stop-color="#6a7a8a"/>
        </linearGradient>
        <linearGradient id="truckBodyGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#ffffff"/>
          <stop offset="100%" stop-color="#e8eef6"/>
        </linearGradient>
      </defs>
      <!-- Sky -->
      <rect width="1440" height="900" fill="url(#skyGrad)"/>
      <!-- Ground -->
      <rect y="680" width="1440" height="220" fill="url(#groundGrad)" opacity=".35"/>
      <!-- Road -->
      <path d="M0 750 L1440 720 L1440 780 L0 810 Z" fill="#6a7a8a" opacity=".25"/>
      <!-- Road centre dashes -->
      <rect x="200" y="762" width="120" height="6" rx="3" fill="white" opacity=".3"/>
      <rect x="480" y="758" width="120" height="6" rx="3" fill="white" opacity=".3"/>
      <rect x="760" y="754" width="120" height="6" rx="3" fill="white" opacity=".3"/>
      <rect x="1040" y="750" width="120" height="6" rx="3" fill="white" opacity=".3"/>
      <rect x="1300" y="746" width="120" height="6" rx="3" fill="white" opacity=".3"/>

      <!-- ── BIG TRUCK (right side) ── -->
      <g transform="translate(620 270)">
        <!-- Body -->
        <rect x="80" y="200" width="680" height="190" rx="8" fill="url(#truckBodyGrad)" stroke="#d0dcea" stroke-width="2"/>
        <!-- Cab -->
        <path d="M80 200 L140 110 L460 110 L500 200 Z" fill="url(#truckBodyGrad)" stroke="#d0dcea" stroke-width="2"/>
        <!-- Windshield -->
        <path d="M155 198 L200 130 L440 130 L470 198 Z" fill="#1b4fb3" opacity=".15"/>
        <!-- Side window -->
        <rect x="160" y="135" width="110" height="60" rx="4" fill="#1b4fb3" opacity=".12"/>
        <!-- Door line -->
        <line x1="285" y1="130" x2="285" y2="200" stroke="#ccd8e8" stroke-width="1.5"/>
        <!-- Bed cover -->
        <rect x="500" y="160" width="260" height="40" rx="4" fill="#e0e8f4" stroke="#c8d4e4" stroke-width="1.5"/>
        <!-- Roll bar -->
        <rect x="510" y="110" width="10" height="90" rx="3" fill="#1b4fb3" opacity=".5"/>
        <rect x="730" y="110" width="10" height="90" rx="3" fill="#1b4fb3" opacity=".5"/>
        <rect x="510" y="112" width="230" height="8" rx="3" fill="#1b4fb3" opacity=".4"/>
        <!-- Auxiliary lights on roll bar -->
        <rect x="540" y="108" width="20" height="10" rx="2" fill="#00b4d8" opacity=".8"/>
        <rect x="590" y="108" width="20" height="10" rx="2" fill="#00b4d8" opacity=".8"/>
        <rect x="640" y="108" width="20" height="10" rx="2" fill="#00b4d8" opacity=".8"/>
        <rect x="690" y="108" width="20" height="10" rx="2" fill="#00b4d8" opacity=".8"/>
        <!-- Beacon -->
        <ellipse cx="642" cy="104" rx="18" ry="10" fill="#f59e0b" opacity=".7"/>
        <!-- Front bumper -->
        <rect x="68" y="240" width="20" height="100" rx="4" fill="#b0bec8" stroke="#a0aeb8" stroke-width="1"/>
        <!-- Headlight -->
        <rect x="72" y="210" width="16" height="22" rx="3" fill="#fff8e0" stroke="#e0d090" stroke-width="1"/>
        <!-- Grill slats -->
        <line x1="70" y1="258" x2="88" y2="258" stroke="#90a0b0" stroke-width="1.5"/>
        <line x1="70" y1="268" x2="88" y2="268" stroke="#90a0b0" stroke-width="1.5"/>
        <line x1="70" y1="278" x2="88" y2="278" stroke="#90a0b0" stroke-width="1.5"/>
        <line x1="70" y1="288" x2="88" y2="288" stroke="#90a0b0" stroke-width="1.5"/>
        <!-- Wheel arches -->
        <path d="M130 390 Q130 340 180 340 Q230 340 230 390 Z" fill="#e8eff8"/>
        <path d="M620 390 Q620 340 670 340 Q720 340 720 390 Z" fill="#e8eff8"/>
        <!-- Wheels -->
        <circle cx="185" cy="390" r="68" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="3"/>
        <circle cx="185" cy="390" r="42" fill="#3a4a5a"/>
        <circle cx="185" cy="390" r="22" fill="#1b4fb3" opacity=".6"/>
        <circle cx="185" cy="390" r="8"  fill="#c8d8e8"/>
        <!-- Wheel bolts -->
        {[0,60,120,180,240,300].map((deg: number) => {
          const r = 34;
          const rad = deg * Math.PI / 180;
          const bx = 185 + r * Math.cos(rad);
          const by = 390 + r * Math.sin(rad);
          return <circle cx={bx} cy={by} r="5" fill="#c8d8e8"/>;
        })}
        <circle cx="668" cy="390" r="68" fill="#2a3a4a" stroke="#1a2a3a" stroke-width="3"/>
        <circle cx="668" cy="390" r="42" fill="#3a4a5a"/>
        <circle cx="668" cy="390" r="22" fill="#1b4fb3" opacity=".6"/>
        <circle cx="668" cy="390" r="8"  fill="#c8d8e8"/>
        {[0,60,120,180,240,300].map((deg: number) => {
          const r = 34;
          const rad = deg * Math.PI / 180;
          const bx = 668 + r * Math.cos(rad);
          const by = 390 + r * Math.sin(rad);
          return <circle cx={bx} cy={by} r="5" fill="#c8d8e8"/>;
        })}
        <!-- Ground shadow -->
        <ellipse cx="420" cy="465" rx="380" ry="20" fill="#6a7a8a" opacity=".12"/>
      </g>

      <!-- Mountain silhouette far background -->
      <path d="M800 500 L950 280 L1100 500 Z" fill="#c8d8e8" opacity=".4"/>
      <path d="M1000 520 L1200 260 L1440 520 Z" fill="#b8cce0" opacity=".35"/>
      <path d="M600 540 L780 340 L960 540 Z" fill="#d0dcea" opacity=".3"/>

      <!-- Dust particles (small dots) -->
      <circle cx="1050" cy="720" r="3" fill="#a0b0c0" opacity=".2"/>
      <circle cx="1100" cy="710" r="2" fill="#a0b0c0" opacity=".15"/>
      <circle cx="1150" cy="725" r="2.5" fill="#a0b0c0" opacity=".18"/>
    </svg>

    <!-- Left gradient overlay for text legibility -->
    <div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(255,255,255,1) 0%, rgba(255,255,255,.85) 40%, rgba(255,255,255,.3) 65%, rgba(255,255,255,0) 100%);"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 px-5 sm:px-8 md:px-16 lg:px-24 w-full max-w-7xl mx-auto">
    <h1 class="font-headline font-black text-secondary leading-none uppercase max-w-3xl tracking-normal"
      style="font-size:clamp(2.5rem, 7vw, 5.5rem);">
      <span class="text-primary block">{t.hero.title2}</span>
      <span class="text-secondary block">{t.hero.title3}</span>
    </h1>

    <p class="mt-6 text-slate-600 max-w-xl font-medium tracking-wide leading-relaxed"
      style="font-size:clamp(.95rem, 1.8vw, 1.15rem);">
      {t.hero.subtitle}
    </p>

    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 w-full sm:w-auto max-w-md sm:max-w-none">
      <a href="#contact"
        class="diagonal-btn bg-primary-gradient text-white px-8 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg text-center justify-center w-full sm:w-auto">
        {t.hero.cta1}
      </a>
      <a href="#catalog"
        class="diagonal-btn border-2 border-secondary text-secondary px-8 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg hover:bg-secondary hover:text-white transition-colors text-center justify-center w-full sm:w-auto">
        {t.hero.cta2}
      </a>
    </div>
  </div>
</section>
